<?xml version="1.0" encoding="utf-8"?>
<templates>
    <t t-inherit="web_studio_ai_fields.AiFieldConfigurationDialog" t-inherit-mode="extension">
        <xpath expr="//t[@t-set-slot='footer']" position="before">
            <h5 class="mt-3">AI Agent</h5>
            <SelectMenu
                choices="aiDialogAgentChoices"
                value="aiAgentState.selectedAgentId"
                onSelect="(val) => this.aiAgentState.selectedAgentId = val"
            />
        </xpath>
    </t>
</templates>
